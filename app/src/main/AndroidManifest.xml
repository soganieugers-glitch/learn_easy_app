<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:theme="@style/Theme.LearnEasy">

        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.LearnEasy.NoActionBar">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <activity
            android:name=".activities.LoginActivity"
            android:exported="false"
            android:theme="@style/Theme.LearnEasy.NoActionBar" />

        <activity
            android:name=".activities.RegisterActivity"
            android:exported="false"
            android:theme="@style/Theme.LearnEasy.NoActionBar" />

        <activity
            android:name=".activities.MainActivity"
            android:exported="false" />

        <activity
            android:name=".activities.LessonsActivity"
            android:exported="false" />

        <activity
            android:name=".activities.LessonDetailActivity"
            android:exported="false" />

        <activity
            android:name=".activities.QuizActivity"
            android:exported="false" />

        <activity
            android:name=".activities.QuizResultActivity"
            android:exported="false" />

        <activity
            android:name=".activities.FlashcardsActivity"
            android:exported="false" />

        <activity
            android:name=".activities.ProgressActivity"
            android:exported="false" />

        <activity
            android:name=".activities.SettingsActivity"
            android:exported="false" />

    </application>

</manifest>
